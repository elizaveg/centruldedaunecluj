---
import '../styles/global.css';
import constataredaunaauto from '../assets/gallery/constatare-dauna-auto.webp';
import documents from '../assets/gallery/documents.webp';
---

<html lang="ro">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Constatare Daune Auto Cluj – RCA & CASCO | Centrul de Daune Auto Cluj</title>

    <meta
            name="description"
            content="Constatare daune auto în Cluj-Napoca. Te ajutăm cu dosarul RCA sau CASCO, acte, constatare și reparație rapidă. Consultanță gratuită, experiență de peste 10 ani."
    />

    <link rel="canonical" href="https://centruldedaunecluj.ro/constatare-daune-auto-cluj" />

    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "AutoRepair",
            "name": "Centrul De Daune Cluj",
            "image": "https://centruldedaunecluj.ro/assets/logo.png",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Str. Soporului 8",
                "addressLocality": "Cluj-Napoca",
                "addressCountry": "RO"
            },
            "telephone": "+40743058942",
            "areaServed": "Cluj-Napoca",
            "priceRange": "0",
            "serviceOffered": {
                "@type": "Service",
                "name": "Constatare daună auto RCA și CASCO"
            }
        }
    </script>
</head>

<body class="font-sans bg-gray-50 text-gray-900 relative">

<!-- HEADER -->
<header class="fixed top-0 left-0 w-full bg-white/95 backdrop-blur-md shadow-md z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
            <!-- LOGO -->
            <a href="/" class="flex items-center space-x-3">
                <img src="/assets/logo.jpeg" alt="Constatare daune auto Cluj – Centrul de Daune" class="h-10 md:h-16 w-auto" />
                <span class="font-bold text-xl text-blue-900">Centrul De Daune Cluj</span>
            </a>

        <!-- MENIU DESKTOP -->
        <nav class="hidden md:flex space-x-8 font-medium">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <a href="/#servicii" class="hover:text-blue-600 transition">Servicii</a>
            <a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
            <a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
            <a href="/#despre" class="hover:text-blue-600 transition">Despre noi</a>
            <a href="/#contact" class="hover:text-blue-600 transition">Contact</a>
        </nav>

        <!-- BURGER MENU MOBILE -->
        <div class="md:hidden">
            <button id="mobile-menu-button" class="text-gray-700 focus:outline-none">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- MOBILE MENU (hidden by default) -->
    <nav id="mobile-menu" class="hidden md:hidden bg-white shadow-md absolute top-full left-0 w-full">
        <div class="flex flex-col p-4 space-y-4">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <a href="#despre" class="hover:text-blue-600 transition">Despre noi</a>
            <a href="#servicii" class="hover:text-blue-600 transition">Servicii</a>
            <a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
            <a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
            <a href="#contact" class="hover:text-blue-600 transition">Contact</a>
        </div>
    </nav>
</header>

<script>
    // Toggle Mobile Menu
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
    });

    // Close Menu
    document.addEventListener('click', (event) => {
        const isClickInsideMenu = menu.contains(event.target);
        const isClickOnButton = btn.contains(event.target);

        if (!isClickInsideMenu && !isClickOnButton) {
            menu.classList.add('hidden');
        }
    });
</script>

<!-- Sticky WhatsApp Button -->
<a href="https://wa.me/40743058942" class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-5 rounded-full shadow-xl transition transform hover:scale-110 z-50">
    📩 Contact rapid
</a>

<!-- Hero Section -->
<section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-28 px-4 text-center">
    <h1 class="text-4xl sm:text-5xl font-extrabold mb-6 animate-fadeInDown">Constatare Daune Auto în Cluj-Napoca – RCA & CASCO</h1>
    <p class="text-lg sm:text-xl mb-8 max-w-3xl mx-auto">
        Dacă ai fost implicat într-un accident rutier în Cluj-Napoca,
        procesul de constatare a daunelor auto este primul pas pentru
        deschiderea dosarului RCA sau CASCO și obținerea despăgubirii.
        Centrul de Daune Cluj te ajută să gestionezi rapid procedura,
        de la constatare până la reparația mașinii.
    </p>
    <p class="text-lg sm:text-xl mb-8 max-w-3xl mx-auto animate-fadeInUp">
        Gestionăm constatarea fizică a daunelor auto în Cluj-Napoca,
        întocmirea dosarului RCA sau CASCO și colaborarea cu asiguratorii.
        Fără drumuri inutile și fără costuri pentru tine.    </p>
    <a href="https://wa.me/40743058942" class="bg-green-500 hover:bg-green-600 transition duration-300 px-10 py-5 rounded-full font-semibold shadow-lg hover:shadow-xl inline-block animate-bounce sm:animate-none">
        📩 Trimite solicitare
    </a>
</section>

<section class="max-w-7xl mx-auto px-4 py-20 space-y-24">

    <!-- Ce este constatarea daunelor -->
    <div class="grid md:grid-cols-2 gap-12 items-center">

        <img
                src={constataredaunaauto.src}
                alt="Constatare Daune Auto Cluj"
                class="max-w-md w-full rounded-xl shadow-lg transform transition duration-500 hover:scale-105"
                loading="lazy"
                decoding="async"
        />

        <div>
            <h2 class="text-3xl font-bold mb-4">Ce înseamnă constatarea daunelor auto?</h2>
            <p class="text-gray-700 mb-4">
                Constatarea daunelor auto este evaluarea pagubelor rezultate după un accident rutier.
                Este obligatorie pentru deschiderea dosarului RCA sau CASCO și trebuie realizată corect
                pentru a obține despăgubirea completă.
            </p>
            <p class="text-gray-700">
                Noi vom întocmi raportul oficial și te ghidăm pas cu pas, astfel încât procesul să fie
                simplu și fără stres.
            </p>
        </div>

    </div>
    <!-- RCA vs CASCO -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
            <h2 class="text-3xl font-bold mb-4">Constatare Daună RCA vs CASCO în Cluj</h2>

            <p class="text-gray-700 mb-4">
                În cazul unei daune RCA, despăgubirea este plătită de asiguratorul
                șoferului vinovat. Pentru CASCO, compania ta de asigurări suportă
                costurile, conform condițiilor poliței.
            </p>

            <p class="text-gray-700 mb-4">
                Procedura de constatare este similară, însă documentele și termenele
                diferă. De aceea este important ca evaluarea să fie făcută corect,
                pentru a evita întârzieri sau despăgubiri parțiale.
            </p>

            <p class="text-gray-700">
                La Centrul de Daune Auto Cluj te ghidăm complet, indiferent de
                asigurator sau tipul poliței.
            </p>
            <div class="text-gray-700">
                Vezi aici <a href="/intocmire-dosar-dauna-cluj" class="text-blue-600 underline">
                întocmirea dosarului de daună
            </a>
            </div>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-lg">
            <h3 class="text-xl font-semibold mb-4">Lucrăm cu toate societățile de asigurare</h3>
            <p class="text-gray-700">
                Gestionăm dosare RCA și CASCO pentru toate companiile din România,
                fără costuri pentru tine.
            </p>
        </div>

    </div>

    <!-- Pași constatare cu carduri hover -->
    <div class="grid md:grid-cols-5 gap-6">
        <div class="bg-white p-6 rounded-xl shadow-lg transform transition duration-500 hover:scale-105 hover:shadow-2xl text-center">
            <span class="text-blue-700 text-3xl font-bold mb-2 inline-block">1</span>
            <h3 class="font-semibold mb-2">Contactează-ne</h3>
            <p class="text-gray-700 text-sm">Telefonic sau WhatsApp. Trimite poze și detalii despre accident.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-lg transform transition duration-500 hover:scale-105 hover:shadow-2xl text-center">
            <span class="text-blue-700 text-3xl font-bold mb-2 inline-block">2</span>
            <h3 class="font-semibold mb-2">Verificăm documentele</h3>
            <p class="text-gray-700 text-sm">Analizăm actele și tipul asigurării (RCA sau CASCO).</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-lg transform transition duration-500 hover:scale-105 hover:shadow-2xl text-center">
            <span class="text-blue-700 text-3xl font-bold mb-2 inline-block">3</span>
            <h3 class="font-semibold mb-2">Constatarea daunelor</h3>
            <p class="text-gray-700 text-sm">Inspectorul evaluează pagubele și întocmește raportul oficial.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-lg transform transition duration-500 hover:scale-105 hover:shadow-2xl text-center">
            <span class="text-blue-700 text-3xl font-bold mb-2 inline-block">4</span>
            <h3 class="font-semibold mb-2">Deschiderea dosarului</h3>
            <p class="text-gray-700 text-sm">Comunicăm cu asiguratorul în numele tău.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-lg transform transition duration-500 hover:scale-105 hover:shadow-2xl text-center">
            <span class="text-blue-700 text-3xl font-bold mb-2 inline-block">5</span>
            <h3 class="font-semibold mb-2">Reparația mașinii</h3>
            <p class="text-gray-700 text-sm">Te direcționăm către service-uri autorizate din Cluj-Napoca.</p>
        </div>
    </div>

    <!-- Acte necesare -->
    <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
            <h2 class="text-3xl font-bold mb-6">Acte necesare pentru constatare</h2>
            <ul class="list-disc list-inside space-y-3 text-gray-700">
                <li>Carte de identitate</li>
                <li>Certificat de înmatriculare</li>
                <li>Permis de conducere</li>
                <li>Polița RCA sau CASCO</li>
                <li>Constatare amiabilă sau proces-verbal de la Poliție</li>
                <li>Împuternicire (dacă mașina este pe firmă)</li>
            </ul>
            <p class="mt-4 text-gray-700">Nu ești sigur ce documente sunt necesare? Te ajutăm gratuit să verifici dosarul înainte de constatare.</p>
        </div>
        <img src={documents.src} alt="Acte constatare daune" class="rounded-xl shadow-lg transform transition duration-500 hover:scale-105" loading="lazy" decoding="async"/>
    </div>

    <!-- Drepturile tale -->
    <div class="bg-white rounded-xl shadow-xl p-10">
        <h2 class="text-3xl font-bold mb-6 text-center">
            Care sunt drepturile tale după un accident rutier?
        </h2>

        <div class="grid md:grid-cols-2 gap-8 text-gray-700">
            <ul class="space-y-4">
                <li>✔ Dreptul de a alege service-ul unde îți repari mașina</li>
                <li>✔ Dreptul la despăgubire completă pentru toate daunele constatate</li>
                <li>✔ Dreptul la
                    <a href="/masina-la-schimb-cluj" class="text-blue-600 underline">
                    mașină la schimb
                </a> în anumite condiții</li>
            </ul>

            <ul class="space-y-4">
                <li>✔ Dreptul la informare transparentă din partea asiguratorului</li>
                <li>✔ Dreptul de a contesta o despăgubire insuficientă</li>
                <li>✔ Dreptul la suport juridic în cazuri complexe</li>
            </ul>
        </div>

        <p class="mt-6 text-gray-700 text-center">
            Noi îți explicăm exact ce ți se cuvine legal și intervenim dacă oferta
            de despăgubire nu reflectă valoarea reală a reparației.
        </p>
    </div>

    <!-- De ce noi -->
    <div class="bg-blue-50 rounded-xl shadow-xl p-10">
        <h2 class="text-3xl font-bold mb-8 text-center">De ce să alegi Centrul de Daune Auto Cluj?</h2>
        <div class="grid md:grid-cols-2 gap-8 text-gray-700">
            <ul class="space-y-4">
                <li class="flex items-center space-x-2">✅ Consultanță gratuită</li>
                <li class="flex items-center space-x-2">✅ Experiență de peste 10 ani</li>
                <li class="flex items-center space-x-2">✅ Colaborare cu service-uri autorizate</li>
            </ul>
            <ul class="space-y-4">
                <li class="flex items-center space-x-2">✅ Suport juridic pentru cazuri complexe</li>
                <li class="flex items-center space-x-2">✅ Zero stres și birocrație minimă</li>
            </ul>
        </div>
    </div>

    <!-- Testimonial -->
    <div class="bg-white rounded-xl shadow-xl p-10 flex flex-col md:flex-row items-center gap-8">
        <img src="/images/client.jpg" alt="Client mulțumit" class="w-32 h-32 rounded-full shadow-lg transform transition duration-500 hover:scale-110" loading="lazy" decoding="async"/>
        <blockquote class="text-gray-700 text-lg">
            "Am avut un accident minor, dar Centrul de Daune Auto Cluj a gestionat totul rapid și fără stres. Recomand cu căldură!"
            <span class="block mt-2 font-semibold">– Andrei M., Cluj-Napoca</span>
        </blockquote>
    </div>
</section>

<section class="py-20 bg-white">
    <!-- FAQ -->
    <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-12">
            Întrebări frecvente
        </h2>

        <div class="space-y-4 text-gray-700">
            <!-- Accordion Item -->
            <details class="bg-gray-50 rounded-xl shadow-sm p-6 cursor-pointer group">
                <summary class="font-semibold text-lg flex justify-between items-center">
                    Cât durează constatarea daunelor?
                    <span class="text-2xl group-open:rotate-45 transition-transform">+</span>
                </summary>
                <p class="text-gray-600 mt-4">
                    De obicei 30–60 minute, iar dosarul se deschide în aceeași zi.
                </p>
            </details>

            <details class="bg-gray-50 rounded-xl shadow-sm p-6 cursor-pointer group">
                <summary class="font-semibold text-lg flex justify-between items-center">
                    Cât costă serviciile?
                    <span class="text-2xl group-open:rotate-45 transition-transform">+</span>
                </summary>
                <p class="text-gray-600 mt-4">
                    Serviciile noastre sunt gratuite pentru clienți. Suntem plătiți de service-urile partenere.
                </p>
            </details>

            <details class="bg-gray-50 rounded-xl shadow-sm p-6 cursor-pointer group">
                <summary class="font-semibold text-lg flex justify-between items-center">
                    Pot veni cu orice asigurator?
                    <span class="text-2xl group-open:rotate-45 transition-transform">+</span>
                </summary>
                <p class="text-gray-600 mt-4">
                    Da, lucrăm cu toate societățile de asigurare din România.
                </p>
            </details>
        </div>
    </div>
</section>

<!-- CTA Final -->
<section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-24 px-4 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-6">Contactează-ne acum</h2>
    <p class="mb-6 text-lg sm:text-xl">Str. Soporului nr. 8, Cluj-Napoca<br />0743 058 942 | contact@centruldedaunecluj.ro</p>
    <p class="mb-8 text-lg sm:text-xl">Program: Luni – Vineri: 09:00 – 18:00</p>
    <a href="https://wa.me/40743058942" class="bg-green-500 hover:bg-green-600 transition duration-300 px-10 py-5 rounded-full font-semibold shadow-lg hover:shadow-xl inline-block animate-bounce sm:animate-none">
        📩 Trimite solicitare
    </a>
</section>

<!-- DISCLAIMER -->
<footer class="bg-gray-900 text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4 text-center">

        <p class="text-white font-semibold mb-2">
            Centrul de Daune Cluj
        </p>

        <p>
            Constatare daune auto, dosare RCA și CASCO,
            mașină la schimb și suport juridic în Cluj-Napoca.
        </p>

        <!-- Social media -->
        <div class="flex justify-center gap-6 mt-6">

            <!-- Facebook -->
            <a href="https://facebook.com" target="_blank" aria-label="Facebook">
                <svg class="w-6 h-6 hover:text-white transition" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M22 12a10 10 0 10-11.5 9.87v-6.99H7.9v-2.88h2.6V9.41c0-2.56 1.52-3.97 3.84-3.97
          1.11 0 2.27.2 2.27.2v2.5h-1.28c-1.26 0-1.65.78-1.65 1.58v1.9h2.81l-.45
          2.88h-2.36v6.99A10 10 0 0022 12z"/>
                </svg>
            </a>

            <!-- Instagram -->
            <a href="https://instagram.com" target="_blank" aria-label="Instagram">
                <svg class="w-6 h-6 hover:text-white transition" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M7.75 2h8.5A5.75 5.75 0 0122 7.75v8.5A5.75 5.75 0 0116.25 22h-8.5A5.75
          5.75 0 012 16.25v-8.5A5.75 5.75 0 017.75 2zm4.25 5a5 5 0 100 10 5 5 0 000-10zm6.25-.88a1.13
          1.13 0 11-2.25 0 1.13 1.13 0 012.25 0zM12 9.5A2.5 2.5 0 1112 14.5 2.5 2.5 0 0112 9.5z"/>
                </svg>
            </a>

            <!-- TikTok -->
            <a href="https://tiktok.com" target="_blank" aria-label="TikTok">
                <svg class="w-6 h-6 hover:text-white transition" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M21 8.29a7.46 7.46 0 01-4.3-1.36v6.09a5.34 5.34 0 11-4.64-5.29v2.3a3.06
          3.06 0 102.18 2.93V2h2.46a5 5 0 004.3 4.29z"/>
                </svg>
            </a>

        </div>

        <p class="mt-6">
            © 2026 Centrul de Daune Cluj
        </p>
    </div>
</footer>

</body>
</html>
