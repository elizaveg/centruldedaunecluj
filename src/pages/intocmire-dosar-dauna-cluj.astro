---
import '../styles/global.css';
const title = "Întocmire Dosar Daună Auto Cluj-Napoca | Centrul De Daune Cluj";
const description = "Te ajutăm cu întocmirea dosarului de daună RCA sau CASCO în Cluj-Napoca. Fără greșeli, fără drumuri inutile, gestionare completă cu asiguratorul.";
const canonical = "https://centruldedaunecluj.ro/intocmire-dosar-dauna-cluj";
---

<html lang="ro">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <!-- SEO Local JSON-LD -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Service",
            "name": "Întocmire Dosar Daună Auto Cluj",
            "provider": {
                "@type": "AutoRepair",
                "name": "Centrul De Daune Cluj",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Cluj-Napoca",
                    "addressCountry": "RO"
                }
            },
            "areaServed": "Cluj-Napoca"
        }
    </script>
</head>

<body class="bg-gray-50 text-gray-800">

<!-- HEADER -->
<header class="fixed top-0 left-0 w-full bg-white/95 backdrop-blur-md shadow-md z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
            <!-- LOGO -->
            <a href="/" class="flex items-center space-x-3">
                <img src="/assets/logo.jpeg" alt="Constatare daune auto Cluj – Centrul de Daune" class="h-10 md:h-16 w-auto" />
                <span class="font-bold text-xl text-blue-900">Centrul De Daune Cluj</span>
            </a>

        <!-- MENIU DESKTOP -->
        <nav class="hidden md:flex space-x-8 font-medium">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <a href="/#servicii" class="hover:text-blue-600 transition">Servicii</a>
            <a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
            <a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
            <a href="/#despre" class="hover:text-blue-600 transition">Despre noi</a>
            <a href="/#contact" class="hover:text-blue-600 transition">Contact</a>
        </nav>

        <!-- BURGER MENU MOBILE -->
        <div class="md:hidden">
            <button id="mobile-menu-button" class="text-gray-700 focus:outline-none">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- MOBILE MENU (hidden by default) -->
    <nav id="mobile-menu" class="hidden md:hidden bg-white shadow-md absolute top-full left-0 w-full">
        <div class="flex flex-col p-4 space-y-4">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <a href="/#servicii" class="hover:text-blue-600 transition">Servicii</a>
            <a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
            <a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
            <a href="/#despre" class="hover:text-blue-600 transition">Despre noi</a>
            <a href="/#contact" class="hover:text-blue-600 transition">Contact</a>
        </div>
    </nav>
</header>

<script>
    // Toggle Mobile Menu
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
    });

    // Close Menu
    document.addEventListener('click', (event) => {
        const isClickInsideMenu = menu.contains(event.target);
        const isClickOnButton = btn.contains(event.target);

        if (!isClickInsideMenu && !isClickOnButton) {
            menu.classList.add('hidden');
        }
    });
</script>

<!-- Sticky WhatsApp Button -->
<a href="https://wa.me/40743058942" class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-5 rounded-full shadow-xl transition transform hover:scale-110 z-50">
    📩 Contact rapid
</a>

<!-- HERO -->
<section class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-30">
    <div class="max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Întocmire Dosar Daună Auto în Cluj-Napoca
        </h1>
        <p class="text-lg md:text-xl mb-8 max-w-3xl mx-auto">
            Te ajutăm să deschizi și să gestionezi corect dosarul de daună RCA sau CASCO,
            fără greșeli și fără întârzieri din partea asiguratorului.
        </p>
        <a href="https://wa.me/40743058942" class="bg-white text-blue-900 font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-gray-100 transition">
            Programează constatarea
        </a>
    </div>
</section>

<!-- INTRO -->
<section class="py-16 max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-6 text-center">
        De ce este importantă întocmirea corectă a dosarului?
    </h2>

    <p class="mb-6 text-gray-700">
        Mulți șoferi din Cluj-Napoca pierd timp și bani din cauza unor dosare incomplete sau
        greșit completate. O simplă omisiune poate duce la întârzieri, despăgubiri parțiale
        sau chiar respingerea cererii.
    </p>

    <p class="mb-6 text-gray-700">
        La Centrul de Daune Cluj gestionăm zilnic dosare RCA și CASCO și știm exact
        ce solicită fiecare asigurator. Verificăm documentele, completăm corect
        cererile și comunicăm direct cu compania de asigurări.
    </p>
</section>

<!-- DOCUMENTE -->
<section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-10 text-center">
            Documente necesare pentru deschiderea unui dosar de daună RCA sau CASCO
        </h2>

        <div class="grid md:grid-cols-2 gap-12">

            <div class="bg-gray-50 p-8 rounded-xl shadow">
                <h3 class="text-xl font-semibold mb-4">Pentru dosar RCA</h3>
                <ul class="space-y-3 text-gray-700">
                    <li>✔ Constatare amiabilă sau proces verbal</li>
                    <li>✔ Talon auto</li>
                    <li>✔ Carte identitate proprietar</li>
                    <li>✔ Permis conducere</li>
                    <li>✔ Polița RCA a șoferului vinovat</li>
                </ul>
            </div>

            <div class="bg-gray-50 p-8 rounded-xl shadow">
                <h3 class="text-xl font-semibold mb-4">Pentru dosar CASCO</h3>
                <ul class="space-y-3 text-gray-700">
                    <li>✔ Polița CASCO</li>
                    <li>✔ Declarație de daună</li>
                    <li>✔ Acte vehicul</li>
                    <li>✔ Carte identitate proprietar</li>
                    <li>✔ Fotografii ale avariilor</li>
                </ul>
            </div>

        </div>
    </div>
</section>

<section class="py-16 max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-10 text-center">
        Pașii pentru deschiderea unui dosar de daună auto
    </h2>
    <div class="space-y-6 text-gray-700">
        <p>
            Procesul de întocmire a unui dosar de daună poate părea complicat pentru
            mulți șoferi, însă cu ajutorul unei echipe specializate acesta devine
            rapid și fără stres.
        </p>

        <p>
            La Centrul de Daune Cluj te ghidăm în fiecare etapă pentru a evita
            întârzierile și pentru a obține despăgubirea corectă din partea
            asiguratorului.
        </p>

        <h3 class="font-semibold text-xl mt-6">1. Analiza accidentului</h3>
        <p>
            Verificăm documentele accidentului și stabilim tipul de dosar: RCA sau
            CASCO.
        </p>

        <h3 class="font-semibold text-xl">2. Verificarea documentelor</h3>
        <p>
            Ne asigurăm că toate actele sunt complete pentru a evita respingerea
            dosarului.
        </p>

        <h3 class="font-semibold text-xl">3. Deschiderea dosarului de daună</h3>
        <p>
            Depunem documentele la asigurator și înregistrăm oficial dosarul.
        </p>

        <h3 class="font-semibold text-xl">4. Programarea constatării</h3>
        <p>
            Programăm constatarea daunelor și verificăm evaluarea realizată de
            asigurator. Poți afla mai multe pe pagina
            <a href="/constatare-daune-auto-cluj" class="text-blue-600 underline">constatare daune auto</a>.
        </p>
    </div>
</section>

<!-- CE FACEM NOI -->
<section class="py-16 max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-10 text-center">
        Cum te ajută Centrul de Daune Cluj cu dosarul de daună
    </h2>

    <div class="grid md:grid-cols-2 gap-8 text-gray-700">
        <ul class="space-y-4">
            <li>✔ Preluăm și verificăm toate documentele</li>
            <li>✔ Deschidem dosarul de daună</li>
            <li>✔ Comunicăm cu asiguratorul</li>
        </ul>

        <ul class="space-y-4">
            <li>✔ Programăm constatarea fizică</li>
            <li>✔ Monitorizăm termenul de despăgubire</li>
            <li>✔ Te ajutăm în caz de ofertă insuficientă</li>
        </ul>
    </div>

    <p class="mt-10 text-center">
        Ai nevoie și de mașină la schimb? Vezi pagina
        <a href="/masina-la-schimb-cluj" class="text-blue-700 font-semibold underline">
            Mașină la schimb în Cluj
        </a>.
    </p>
</section>

<!-- CTA FINAL -->
<section class="bg-blue-900 text-white py-16 text-center">
    <h2 class="text-3xl font-bold mb-6">
        Ai avut un accident? Nu pierde timp.
    </h2>
    <p class="mb-8">
        Îți gestionăm dosarul rapid și corect.
    </p>
    <a href="https://wa.me/40743058942" class="bg-white text-blue-900 px-8 py-4 rounded-lg font-semibold shadow hover:bg-gray-200 transition">
        Programează acum
    </a>
</section>

<!-- DISCLAIMER -->
<footer class="bg-gray-900 text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4 text-center">

        <p class="text-white font-semibold mb-2">
            Centrul de Daune Cluj
        </p>

        <p>
            Constatare daune auto, dosare RCA și CASCO,
            mașină la schimb și suport juridic în Cluj-Napoca.
        </p>

        <p class="mt-4">
            © 2026 Centrul de Daune Cluj
        </p>

    </div>
</footer>

</body>
</html>
