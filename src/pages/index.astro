			<img src="/assets/team/maria.jpeg" alt="Maria Posteuca" class="w-32 h-32 mx-auto rounded-full mb-4 object-cover" loading="lazy" decoding="async"/>
			<h3 class="text-xl font-semibold mb-2">Maria Marioara</h3>
