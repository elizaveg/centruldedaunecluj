			</div>

			<!-- 8 -->
			<div class="bg-white p-8 rounded-2xl shadow-md hover:shadow-xl transition">
				<h3 class="text-xl font-semibold mb-3">Dosare Vătămări Corporale</h3>
				<p class="text-gray-600">
					Gestionăm dosarele pentru victimele accidentelor rutiere
