				<p class="text-gray-600">
					Colaborăm cu avocat specializat pentru cazuri
					cu vătămări corporale și despăgubiri.
				</p>
			</div>
		</div>
	</div>
</section>

<!-- Cum Te Ajutăm Concret -->
<section class="py-20 bg-gray-50">
	<div class="max-w-6xl mx-auto px-4">

		<h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
			Cum Te Ajutăm Concret
		</h2>

		<div class="grid md:grid-cols-2 gap-12 items-center">

			<!-- IMAGINE -->
			<div>
				<img
					src={handshake.src}
					alt="Gestionare dosar daună auto Cluj"
					class="rounded-2xl shadow-xl w-full object-cover"
					loading="lazy"
				/>
			</div>

			<!-- TEXT -->
			<div class="text-gray-700 text-lg leading-relaxed space-y-6">

				<p>
					Oferim suport complet pentru gestionarea dosarului de daună auto în
