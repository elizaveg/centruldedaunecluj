---
import '../styles/global.css';
import herocar from '../assets/hero-car.jpeg';
import logo from '../../public/assets/logo.jpeg';
import handshake from '../assets/gallery/handshake.webp';
---

<html lang="ro">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Constatare Daune Auto Cluj | Dosar Daună RCA & CASCO</title>
	<meta name="description" content="Ai accident auto în Cluj-Napoca? Te ajutăm cu constatare daune, dosar RCA sau CASCO, mașină la schimb și despăgubiri corecte." />
	<link rel="canonical" href="https://centruldedaunecluj.ro/" />
	<meta property="og:title" content="Centrul de Daune Auto Cluj" />
	<meta property="og:description" content="Ai accident auto în Cluj-Napoca? Te ajutăm cu constatare daune, dosar RCA/CASCO și mașină la schimb. Consultanță gratuită." />
	<meta property="og:image" content="https://centruldedaunecluj.ro/social-preview.jpg" />
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://centruldedaunecluj.ro/" />

	<!-- SEO Local JSON-LD -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Centrul De Daune Cluj",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Str. Soporului 8",
				"addressLocality": "Cluj-Napoca",
				"postalCode": "400000",
				"addressCountry": "RO"
			},
			"telephone": "+40743058942",
			"url": "https://centruldedaunecluj.ro",
			"priceRange": "0",
			"sameAs": ["https://www.facebook.com/centruldedaunecluj"]
		}
	</script>
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "Ce trebuie să fac după un accident auto?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "După accident trebuie completat formularul de constatare amiabilă sau anunțată poliția, apoi se deschide dosarul de daună la asigurator. Echipa noastră te ajută cu întocmirea documentelor și gestionarea procesului."
					}
				},
				{
					"@type": "Question",
					"name": "Cât durează constatarea daunelor auto?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Constatarea daunelor poate dura între 24 și 72 de ore, în funcție de asigurator și complexitatea cazului."
					}
				},
				{
					"@type": "Question",
					"name": "Pot primi mașină la schimb?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Da, dacă nu ești vinovat de accident, ai dreptul legal la mașină la schimb pe perioada reparației."
					}
				}
			]
		}
	</script>
</head>
<body class="font-sans bg-gray-50 text-gray-900 pt-20">

<!-- HEADER -->
<header class="fixed top-0 left-0 w-full bg-white/95 backdrop-blur-md shadow-md z-50">
	<div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
		<!-- LOGO -->
		<a href="/" class="flex items-center space-x-3">
			<img src={logo.src} alt="Constatare daune auto Cluj – Centrul de Daune" class="h-10 md:h-16 w-auto" />
			<span class="font-bold text-xl text-blue-900">Centrul De Daune Cluj</span>
		</a>

		<!-- MENIU DESKTOP -->
		<nav class="hidden md:flex space-x-8 font-medium">
			<a href="/" class="hover:text-blue-600 transition">Home</a>
			<a href="#servicii" class="hover:text-blue-600 transition">Servicii</a>
			<a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
			<a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
			<a href="#despre" class="hover:text-blue-600 transition">Despre noi</a>
			<a href="#contact" class="hover:text-blue-600 transition">Contact</a>
		</nav>

		<!-- BURGER MENU MOBILE -->
		<div class="md:hidden">
			<button id="mobile-menu-button" class="text-gray-700 focus:outline-none">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
		</div>
	</div>

	<!-- MOBILE MENU (hidden by default) -->
	<nav id="mobile-menu" class="hidden md:hidden bg-white shadow-md absolute top-full left-0 w-full">
		<div class="flex flex-col p-4 space-y-4">
			<a href="/" class="hover:text-blue-600 transition">Home</a>
			<a href="#servicii" class="hover:text-blue-600 transition">Servicii</a>
			<a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
			<a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
			<a href="#despre" class="hover:text-blue-600 transition">Despre noi</a>
			<a href="#contact" class="hover:text-blue-600 transition">Contact</a>
		</div>
	</nav>
</header>

<script>
	// Toggle Mobile Menu
	const btn = document.getElementById('mobile-menu-button');
	const menu = document.getElementById('mobile-menu');

	btn.addEventListener('click', () => {
		menu.classList.toggle('hidden');
	});

	// Close Menu
	document.addEventListener('click', (event) => {
		const isClickInsideMenu = menu.contains(event.target);
		const isClickOnButton = btn.contains(event.target);

		if (!isClickInsideMenu && !isClickOnButton) {
			menu.classList.add('hidden');
		}
	});
</script>

<!-- Sticky WhatsApp Button -->
<a href="https://wa.me/40743058942 " class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-5 rounded-full shadow-xl transition transform hover:scale-110 z-50">
	📩 Contact rapid
</a>

<!-- HERO -->
<section id="home" class="relative bg-blue-900 text-white h-[60vh] flex items-center justify-center">
	<img src={herocar.src} alt="Centrul de daune auto din Cluj-Napoca – constatare RCA" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" decoding="async"/>

	<div class="relative z-10 text-center px-4">
		<h1 class="text-4xl sm:text-5xl font-extrabold mb-4 leading-tight">
			Centrul de Daune Auto din Cluj-Napoca – Fără Stres și Fără Costuri
		</h1>

		<p class="text-lg sm:text-xl mb-8">
			Consultanță completă pentru dosare de daună RCA și CASCO în Cluj-Napoca
		</p>

		<!-- CTA BUTTONS -->
		<div class="flex flex-col sm:flex-row gap-4 justify-center">

			<a href="tel:+40743058942"
			   class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-lg shadow-lg transition">
				📞 Sună acum
			</a>

			<a href="https://wa.me/40743058942"
			   class="bg-green-500 hover:bg-green-600 text-white font-semibold px-8 py-4 rounded-lg shadow-lg transition">
				💬 WhatsApp rapid
			</a>

		</div>

	</div>
</section>

<!-- PROCES ACCIDENT AUTO -->
<section class="py-20 px-4 max-w-6xl mx-auto">

	<h2 class="text-3xl font-bold text-center mb-6">
		Ce trebuie să faci după un accident auto în Cluj-Napoca
	</h2>

	<p class="text-center text-gray-600 max-w-3xl mx-auto mb-12">
		Dacă ai fost implicat într-un accident rutier, este important să urmezi pașii corecți
		pentru deschiderea dosarului de daună și obținerea despăgubirii. Echipa noastră
		de la <strong>Centrul de Daune Cluj</strong> te ajută să gestionezi rapid procesul
		de <a href="/constatare-daune-auto-cluj" class="text-blue-600 underline">constatare a daunelor auto în Cluj</a>,
		fără drumuri inutile și fără birocrație.
	</p>
	<div class="bg-white p-8 rounded-2xl shadow-md hover:shadow-xl transition">
		<h3 class="text-xl font-semibold mb-3">
			Constatare Daune Auto Cluj
		</h3>

		<p class="text-gray-600">
			Constatarea daunelor și deschiderea dosarului RCA sau CASCO
			cu suport complet din partea echipei noastre.
		</p>

		<a href="/constatare-daune-auto-cluj"
		   class="text-blue-600 font-semibold mt-3 inline-block">
			Află mai multe →
		</a>
	</div>
	<br >

	<div class="grid gap-10 sm:grid-cols-3">

		<!-- PAS 1 -->
		<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
			<h3 class="text-xl font-semibold mb-3">
				1. Contactează-ne imediat după accident
			</h3>

			<p class="text-gray-600">
				După producerea accidentului, ne poți trimite fotografii cu
				avariile mașinii și documentele disponibile. Îți explicăm
				ce acte sunt necesare și te ghidăm pentru
				deschiderea corectă a dosarului de daună RCA sau CASCO.
			</p>

			<p class="text-gray-600 mt-3">
				Află mai multe despre
				<a href="/intocmire-dosar-dauna-cluj" class="text-blue-600 underline">
					întocmirea dosarului de daună
				</a>.
			</p>
		</div>

		<!-- PAS 2 -->
		<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
			<h3 class="text-xl font-semibold mb-3">
				2. Analizăm și pregătim documentația
			</h3>

			<p class="text-gray-600">
				Inspectorul nostru verifică documentele și constatarea
				daunelor pentru a evita problemele cu asiguratorul.
				Ne ocupăm de completarea formularelor și de
				comunicarea cu compania de asigurări.
			</p>

			<p class="text-gray-600 mt-3">
				Serviciul nostru de
				<a href="/constatare-daune-auto-cluj" class="text-blue-600 underline">
					constatare daune auto în Cluj-Napoca
				</a>
				te ajută să obții evaluarea corectă a pagubelor.
			</p>
		</div>

		<!-- PAS 3 -->
		<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
			<h3 class="text-xl font-semibold mb-3">
				3. Reparăm mașina și urmărim despăgubirea
			</h3>

			<p class="text-gray-600">
				Te direcționăm către un service partener autorizat,
				iar dacă este necesar te ajutăm să obții
				<a href="/masina-la-schimb-cluj" class="text-blue-600 underline">
					mașină la schimb pe perioada reparației
				</a>.
			</p>

			<p class="text-gray-600 mt-3">
				Monitorizăm întreg procesul până la finalizarea
				reparației și plata despăgubirii.
			</p>
		</div>

	</div>

</section>

<!-- De ce să ne alegi -->
<section class="py-16 bg-white">
