---
const title = "Mașină la Schimb Cluj-Napoca după Accident | Gratuit prin RCA";
const description = "Primește mașină la schimb în Cluj-Napoca pe perioada reparației auto. Gratuit prin RCA-ul șoferului vinovat.";
const canonical = "https://centruldedaunecluj.ro/masina-la-schimb-cluj";
import '../styles/global.css';
import carkeys from '../assets/gallery/car-keys.webp';
---

<html lang="ro">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Service",
            "name": "Mașină la schimb Cluj",
            "provider": {
                "@type": "AutoRepair",
                "name": "Centrul De Daune Cluj",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Cluj-Napoca",
                    "addressCountry": "RO"
                }
            },
            "areaServed": "Cluj-Napoca"
        }
    </script>
</head>

<body class="bg-gray-50 text-gray-800 pt-20">

<!-- HEADER -->
<header class="fixed top-0 left-0 w-full bg-white/95 backdrop-blur-md shadow-md z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
            <!-- LOGO -->
            <a href="/" class="flex items-center space-x-3">
                <img src="/assets/logo.jpeg" alt="Constatare daune auto Cluj – Centrul de Daune" class="h-10 md:h-16 w-auto" />
                <span class="font-bold text-xl text-blue-900">Centrul De Daune Cluj</span>
            </a>

        <nav class="hidden md:flex space-x-8 font-medium">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <a href="/#servicii" class="hover:text-blue-600 transition">Servicii</a>
            <a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
            <a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
            <a href="/#despre" class="hover:text-blue-600 transition">Despre noi</a>
            <a href="/#contact" class="hover:text-blue-600 transition">Contact</a>
        </nav>

        <!-- BURGER MENU MOBILE -->
        <div class="md:hidden">
            <button id="mobile-menu-button" class="text-gray-700 focus:outline-none">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden bg-white shadow-md absolute top-full left-0 w-full">
        <div class="flex flex-col p-4 space-y-4">
            <a href="/" class="hover:text-blue-600 transition">Home</a>
            <a href="/#servicii" class="hover:text-blue-600 transition">Servicii</a>
            <a href="/intocmire-dosar-dauna-cluj" class="hover:text-blue-600 transition">Întocmire dosar daună</a>
            <a href="/masina-la-schimb-cluj" class="hover:text-blue-600 transition">Mașină la schimb</a>
            <a href="/#despre" class="hover:text-blue-600 transition">Despre noi</a>
            <a href="/#contact" class="hover:text-blue-600 transition">Contact</a>
        </div>
    </nav>
</header>

<script>
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
    });

    // Close Menu
    document.addEventListener('click', (event) => {
        const isClickInsideMenu = menu.contains(event.target);
        const isClickOnButton = btn.contains(event.target);

        if (!isClickInsideMenu && !isClickOnButton) {
            menu.classList.add('hidden');
        }
    });
</script>

<!-- Sticky WhatsApp Button -->
<a href="https://wa.me/40743058942" class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-5 rounded-full shadow-xl transition transform hover:scale-110 z-50">
    📩 Contact rapid
</a>

<!-- HERO -->
<section class="relative bg-gradient-to-r from-blue-900 to-blue-700 text-white py-24">
    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">Mașină la Schimb în Cluj-Napoca după Accident</h1>
        <p class="text-lg md:text-xl mb-8 max-w-3xl mx-auto">
            Primești autoturism de înlocuire pe perioada reparației, gratuit prin RCA-ul șoferului vinovat.  📞 Sună acum: 0743 058 942
        </p>

        <a href="https://wa.me/40743058942" class="bg-white text-gray-900 px-8 py-4 rounded-lg font-semibold shadow-lg hover:bg-gray-200 transition">
            Sună acum
        </a>
    </div>
    <div class="absolute inset-0 opacity-20">
        <img src={carkeys.src} alt="Mașină la schimb Cluj" class="w-full h-full object-cover" loading="eager" decoding="async"/>
    </div>
</section>

<!-- BENEFICII -->
<section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-12">De ce să alegi serviciul nostru</h2>
        <div class="grid md:grid-cols-3 gap-8">
            <div class="p-6 bg-white rounded-2xl shadow-md hover:shadow-xl transition transform hover:-translate-y-1">
                <div class="text-4xl mb-3">🚗</div>
                <h3 class="font-semibold text-xl mb-2">Mașină la schimb imediat</h3>
                <p>Primești vehiculul de înlocuire pe întreaga durată a reparației.</p>
            </div>
            <div class="p-6 bg-white rounded-2xl shadow-md hover:shadow-xl transition transform hover:-translate-y-1">
                <div class="text-4xl mb-3">⚡</div>
                <h3 class="font-semibold text-xl mb-2">Fără costuri ascunse</h3>
                <p>Serviciul este acoperit prin RCA-ul șoferului vinovat, fără taxe suplimentare.</p>
            </div>
            <div class="p-6 bg-white rounded-2xl shadow-md hover:shadow-xl transition transform hover:-translate-y-1">
                <div class="text-4xl mb-3">📄</div>
                <h3 class="font-semibold text-xl mb-2">Proces rapid</h3>
                <p>Gestionăm toate documentele și comunicarea cu asiguratorul pentru tine.</p>
            </div>
        </div>
    </div>
</section>

<!-- CUM FUNCTIONEAZA PROFESIONAL -->
<section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-8 text-center">Cum funcționează procesul</h2>

        <p class="text-gray-700 mb-6 text-lg">
            Procesul nostru este simplu și eficient, astfel încât tu să primești mașina la schimb cât mai rapid și fără complicații:
        </p>

        <ol class="list-decimal list-inside text-gray-700 space-y-4 text-lg">
            <li>
                <strong>Deschidem dosarul:</strong> Contactează-ne și noi deschidem dosarul tău de daună cu asiguratorul.
            </li>
            <li>
                <strong>Programăm constatarea:</strong> Stabilim împreună momentul pentru constatarea daunelor la service-ul partener.
            </li>
            <li>
                <strong>Preluăm mașina avariată:</strong> Vehiculul tău este transportat și monitorizat pe întreaga perioadă de reparație.
            </li>
            <li>
                <strong>Primești mașină la schimb:</strong> În tot acest timp, beneficiezi de un autoturism de înlocuire complet funcțional, gratuit.
            </li>
        </ol>
        <br >

        <p class="text-gray-700 mb-6 text-lg">
            Dacă nu ai făcut încă constatarea daunelor vezi
            <a href="/constatare-daune-auto-cluj" class="text-blue-600 underline">constatare daune auto în Cluj.</a>
        </p>
    </div>
</section>

<!-- CONDITII REFORMULATE -->
<section id="eligibilitate" class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-8 text-center">Când serviciul este gratuit</h2>

        <p class="text-gray-700 mb-8 text-lg text-center">
            Beneficiezi de mașină la schimb fără costuri, dacă sunt respectate condițiile legale și de asigurare. Noi ne ocupăm de tot procesul pentru ca tu să nu ai griji.
        </p>

        <div class="grid md:grid-cols-2 gap-10">
            <!-- Condiții legale -->
            <div class="flex flex-col space-y-4">
                <h3 class="text-xl font-semibold text-blue-900 mb-2">Condiții legale</h3>
                <p class="text-gray-700">
                    Serviciul este gratuit dacă nu ești vinovat de producerea accidentului și dacă există un dosar RCA deschis pe numele tău.
                </p>
                <ul class="list-disc list-inside text-gray-700 space-y-2">
                    <li>✔ Nu ești vinovat de accident</li>
                    <li>✔ Dosar RCA existent și valid</li>
                    <li>✔ Mașina este în reparație la service autorizat</li>
                </ul>
            </div>

            <!-- Beneficii și limite -->
            <div class="flex flex-col space-y-4">
                <h3 class="text-xl font-semibold text-blue-900 mb-2">Beneficii și limite</h3>
                <p class="text-gray-700">
                    În tot acest timp, primești un autoturism de înlocuire complet funcțional, fără costuri ascunse, în limita aprobării asiguratorului.
                </p>
                <ul class="list-disc list-inside text-gray-700 space-y-2">
                    <li>✔ Pe întreaga durată a reparației</li>
                    <li>✔ Gratuit prin RCA-ul șoferului vinovat</li>
                    <li>✔ Fără taxe sau surprize suplimentare</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- CTA FINAL -->
<section class="bg-blue-900 text-white py-20 text-center">
    <h2 class="text-3xl font-bold mb-6">Nu rămâne fără mașină</h2>
    <p class="mb-8 text-lg">Suntem aici să te ajutăm imediat și fără stres.</p>
    <a href="https://wa.me/40743058942" class="bg-white text-gray-900 px-8 py-4 rounded-lg font-semibold shadow-lg hover:bg-gray-200 transition">
        Contactează-ne acum
    </a>
</section>

<!-- DISCLAIMER -->
<footer class="bg-gray-900 text-gray-400 py-10">
    <div class="max-w-6xl mx-auto px-4 text-center">

        <p class="text-white font-semibold mb-2">
            Centrul de Daune Cluj
        </p>

        <p>
            Constatare daune auto, dosare RCA și CASCO,
            mașină la schimb și suport juridic în Cluj-Napoca.
        </p>

        <!-- Social media -->
        <div class="flex justify-center gap-6 mt-6">

            <!-- Facebook -->
            <a href="https://facebook.com" target="_blank" aria-label="Facebook">
                <svg class="w-6 h-6 hover:text-white transition" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M22 12a10 10 0 10-11.5 9.87v-6.99H7.9v-2.88h2.6V9.41c0-2.56 1.52-3.97 3.84-3.97
          1.11 0 2.27.2 2.27.2v2.5h-1.28c-1.26 0-1.65.78-1.65 1.58v1.9h2.81l-.45
          2.88h-2.36v6.99A10 10 0 0022 12z"/>
                </svg>
            </a>

            <!-- Instagram -->
            <a href="https://instagram.com" target="_blank" aria-label="Instagram">
                <svg class="w-6 h-6 hover:text-white transition" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M7.75 2h8.5A5.75 5.75 0 0122 7.75v8.5A5.75 5.75 0 0116.25 22h-8.5A5.75
          5.75 0 012 16.25v-8.5A5.75 5.75 0 017.75 2zm4.25 5a5 5 0 100 10 5 5 0 000-10zm6.25-.88a1.13
          1.13 0 11-2.25 0 1.13 1.13 0 012.25 0zM12 9.5A2.5 2.5 0 1112 14.5 2.5 2.5 0 0112 9.5z"/>
                </svg>
            </a>

            <!-- TikTok -->
            <a href="https://tiktok.com" target="_blank" aria-label="TikTok">
                <svg class="w-6 h-6 hover:text-white transition" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M21 8.29a7.46 7.46 0 01-4.3-1.36v6.09a5.34 5.34 0 11-4.64-5.29v2.3a3.06
          3.06 0 102.18 2.93V2h2.46a5 5 0 004.3 4.29z"/>
                </svg>
            </a>

        </div>

        <p class="mt-6">
            © 2026 Centrul de Daune Cluj
        </p>
    </div>
</footer>

</body>
</html>
